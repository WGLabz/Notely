{
  "name": "notely",
  "version": "0.1.0",
  "private": true,
  "description": "Notely desktop markdown notes app.",
  "author": {
    "name": "Notely Team",
    "email": "hello@notely.app"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "assets:icon": "node scripts/generate-icon.cjs",
    "release:clean": "node scripts/clean-release-artifacts.cjs",
    "build": "node scripts/build.cjs",
    "start": "node scripts/launch-electron.cjs",
    "release:collect": "node scripts/copy-exe-to-release.cjs",
    "pack:win": "npm run release:clean && npm run assets:icon && npm run build && node scripts/run-electron-builder.cjs --win --dir",
    "dist:win": "npm run release:clean && npm run assets:icon && npm run build && node scripts/run-electron-builder.cjs --win nsis portable && npm run release:collect",
    "lint:markdown": "markdownlint-cli2",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:p2p": "node scripts/p2p-harness.cjs",
    "test:p2p:packaged": "node scripts/p2p-packaged-validation.cjs",
    "ci:check": "npm run lint && npm run build && npm run lint:markdown && npm run test"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@uiw/react-codemirror": "^4.25.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.405.0",
    "markdown-it": "^14.1.0",
    "md-to-pdf": "^5.2.5",
    "mermaid": "^11.6.0",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^4.3.136",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-lint": "^10.0.1",
    "remark-preset-lint-recommended": "^7.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "electron": "^37.2.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "markdownlint-cli2": "^0.18.1",
    "png-to-ico": "^2.1.8",
    "pngjs": "^7.0.0",
    "prettier": "^3.4.0",
    "vite": "^6.3.5",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "app.notely.desktop",
    "productName": "Notely",
    "directories": {
      "output": ".artifacts",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/ai/**/*",
      "scripts/launch-electron.cjs",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "icon": "build/icon.ico",
      "publisherName": "Notely",
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "copyright": "Copyright (c) 2026 Notely",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
