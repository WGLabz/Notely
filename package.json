{
  "name": "tcl-mithapur-notes-app",
  "version": "0.1.0",
  "private": true,
  "description": "Local Electron markdown notes app for TCL Mithapur discovery notes.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && node scripts/launch-electron.cjs --dev\"",
    "build": "vite build",
    "start": "node scripts/launch-electron.cjs"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@uiw/react-codemirror": "^4.25.10",
    "lucide-react": "^0.405.0",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-lint": "^10.0.1",
    "remark-preset-lint-recommended": "^7.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "electron": "^37.2.0",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
